{
  "manifest_version": 2,
  "name": "YourAIGuard",
  "version": "3.0.1",
  "description": "Instant, private reasoning-quality assessment for every ChatGPT response. No account, no API key — all analysis runs on your device.",
  "author": "vspendyala",
  "homepage_url": "https://github.com/VPyndyala/YourAIGuard",
  "browser_specific_settings": {
    "gecko": {
      "id": "youraiguard@vspendyala",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_icon": "icons/icon48.png",
    "default_title": "YourAIGuard",
    "default_popup": "popup.html"
  },
  "background": {
    "page": "background.html",
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage"
  ],
  "web_accessible_resources": [
    "criteria_model.json",
    "instability_params.json",
    "transformers.min.js",
    "models/*"
  ],
  "content_security_policy": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
}
