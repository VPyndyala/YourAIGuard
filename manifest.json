{
  "manifest_version": 2,
  "name": "YourAIGuard",
  "version": "1.1.0",
  "description": "Helps you stay safe by checking the trustworthiness of AI responses on ChatGPT.",
  "author": "VPyndyala",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_action": {
    "default_icon": "icons/icon48.png",
    "default_title": "YourAIGuard"
  },
  "background": {
    "page": "background.html",
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage"
  ],
  "web_accessible_resources": [
    "gate_model.json",
    "rung_model.json",
    "transformers.min.js"
  ],
  "content_security_policy": "script-src 'self' 'unsafe-eval' 'unsafe-inline' 'wasm-unsafe-eval'; object-src 'self';"
}
